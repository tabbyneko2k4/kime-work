---
import { Picture, getImage } from "astro:assets";

import Layout from "../layouts/Layout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import PageDecorBanner from "../components/PageDecorBanner.astro";
import InfoWindow from "../components/InfoWindow.astro";
import PlayIcon from "../components/icons/PlayIcon.astro";
import { fetchExperiences } from "../lib/hygraph";

import kimeyuPFP from "../assets/images/kimeyu.jpg";
import { fetchSiteProfile, fetchAboutPageConfig } from "../lib/hygraph";

// ==========================================================
// DATA & CONFIG
// ==========================================================

const [profileData, aboutPageConfig] = await Promise.all([
  fetchSiteProfile().catch((err) => {
    console.error("Failed to fetch site profile:", err.message);
    return null;
  }),
  fetchAboutPageConfig().catch((err) => {
    console.error("Failed to fetch about page config:", err.message);
    return null;
  })
]);

const avatarSource = profileData?.avatar?.url || kimeyuPFP;
const isRemoteAvatar = !!profileData?.avatar?.url;

// Bio Fallbacks
const defaultBio = "Born in VietNam in 2005. Worked as a freelancer who has creative journey began with anime to form a way of seeing the world through emotion, color, and movement.";
const defaultQuote = "Curiosity in motion, stories in rhythm.";

const bioText = aboutPageConfig?.bioText || defaultBio;
const bioQuote = aboutPageConfig?.bioQuote || defaultQuote;

let experiencesData = await fetchExperiences().catch((err) => {
  console.error("Failed to fetch experiences:", err.message);
  return [];
});


if (experiencesData.length === 0) {
  experiencesData = [
    {
      id: "1",
      category: "PROFESSIONAL",
      year: "2026",
      description:
        '"Declaring The New Era" - Official Trailer | Garena - Đấu Trường Danh Vọng (AOG) Spring 2026 | Collaborator Motion Designer (via Antiantiart).',
    },
    {
      id: "2",
      category: "PROFESSIONAL",
      year: "2024",
      description:
        "VNG Corporation | Collaborator Video Editor Edited promotional video content",
    },
    {
      id: "3",
      category: "CHARITY",
      year: "2025",
      description:
        "INFLORESCENCE - HATSUNE MIKU UNOFFICIAL CONCEPT ARTBOOK BY SORAMOYO-YA | Created floral-themed illustrations for a charity artbook; all proceeds were donated to support social welfare.",
    },
    {
      id: "4",
      category: "INDEPENDENT",
      description:
        "Working on upcoming personal motion and illustration projects.",
    },
  ];
}

const ENUM_MAP: Record<string, string> = {
  PROFESSIONAL: "Professional Collaborations",
  CHARITY: "Community & Charity",
  INDEPENDENT: "Independent Projects",
};


const COLLAB_KEYS = Object.keys(ENUM_MAP);

const AVATAR_WIDTHS = [150, 300, 450, 500];
const AVATAR_MOBILE_PX = 150;
const AVATAR_DESKTOP_PX = 170;

const avatarSizes = `(max-width: 1023px) ${AVATAR_MOBILE_PX}px, ${AVATAR_DESKTOP_PX}px`;

const toolsFocus = [
  { id: "ae", name: "Ae", variant: "ae" },
  { id: "ai", name: "Ai", variant: "ai" },
  { id: "ps", name: "Ps", variant: "ps" },
];

const valueCards = [
  {
    id: "1",
    title: "MOVIE",
    desc: "Motion graphics, 2D Music Video, 2D Advertising",
    variant: "movie",
  },
  {
    id: "2",
    title: "ILLUST",
    desc: "Character Design, Background, Landscape.",
    variant: "illust",
  },
  {
    id: "3",
    title: "DESIGN",
    desc: "Graphics, Package, Web, Editorial",
    variant: "design",
  },
];

const avifSrcset = (
  await Promise.all(
    AVATAR_WIDTHS.map((w) =>
      getImage({ src: kimeyuPFP, format: "avif", width: w }),
    ),
  )
)
  .map((img, i) => `${img.src} ${AVATAR_WIDTHS[i]}w`)
  .join(", ");
---

<Layout title="Kimeyu Work - About">
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      imagesrcset={avifSrcset}
      imagesizes={avatarSizes}
      type="image/avif"
      fetchpriority="high"
    />
  </Fragment>

  <Fragment slot="banner">
    <div class="banner-headers">
      <SectionHeader title="ABOUT ME" isBanner={true} align="responsive" />
      <SectionHeader
        title="ABOUT"
        subtitle="プロフィール"
        subtitleOrientation="horizontal"
        align="responsive"
      />
    </div>
  </Fragment>

  <div class="page-layout wrapper banner-spacing">
    <nav class="sidebar-nav">
      <PageDecorBanner
        text="ABOUT ME"
        href="#about-me"
        variant="secondary"
        compact
        checkerPosition="end"
      />
      <PageDecorBanner
        text="VALUE"
        href="#value"
        variant="secondary"
        compact
        checkerPosition="end"
      />
      <PageDecorBanner
        text="EXPERIENCES"
        href="#experiences"
        variant="secondary"
        compact
        checkerPosition="end"
      />
    </nav>

    <div class="page-content">
      <!-- ================= SECTION: HERO ================= -->
      <PageDecorBanner
        id="banner-about-me"
        text="ABOUT ME"
        variant="secondary"
      />

      <header
        id="about-me"
        class="profile-hero-header grid-area-hero"
        style={`--avatar-min: ${AVATAR_MOBILE_PX}px; --avatar-max: ${AVATAR_DESKTOP_PX}px;`}
      >
        <div class="avatar-container">
          {isRemoteAvatar ? (
            <Picture
              src={avatarSource as string}
              inferSize={true}
              formats={["avif", "webp"]}
              fallbackFormat="jpg"
              alt="Kimeyu Profile Picture"
              fetchpriority="high"
              class="avatar-img"
              widths={AVATAR_WIDTHS}
              sizes={avatarSizes}
            />
          ) : (
            <Picture
              src={kimeyuPFP}
              formats={["avif", "webp"]}
              fallbackFormat="jpg"
              alt="Kimeyu Profile Picture"
              fetchpriority="high"
              class="avatar-img"
              widths={AVATAR_WIDTHS}
              sizes={avatarSizes}
            />
          )}
        </div>

        <div class="info-banner">
          <div class="info-title-group">
            <h1 class="info-name">KIMEYU</h1>
            <PlayIcon class="icon-play" />
          </div>
        </div>
      </header>

      <!-- ================= SECTION: TOOLS ================= -->
      <section id="creative-tools" class="tools-section">
        <div class="tools-section__inner">
          <div class="tools-section__head">
            <PageDecorBanner
              id="banner-creative-tools"
              text="TOOLS FOCUS"
              compact
              checkerPosition="both"
            />
          </div>

          <div class="tools-grid">
            {
              toolsFocus.map((tool) => (
                <div class={`tool-card tool-card--${tool.variant}`}>
                  <span class="tool-name">{tool.name}</span>
                </div>
              ))
            }
            <div class="tool-card tool-card--custom">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 50 50"
                fill="currentColor"
                style="width: 55%; height: 55%;"
              >
                <path
                  d="M37,4H13c-4.962,0-9,4.037-9,9v24c0,4.963,4.038,9,9,9h24c4.962,0,9-4.037,9-9V13C46,8.037,41.962,4,37,4z M34.772,29.527c-0.95,0.745-1.795,1.109-2.082,1.218l-5.35,2.204c-0.064,0.027-0.091,0.105-0.055,0.168l0.75,1.15c0.268,0.427,0.373,0.832,0.373,1.309c0,1.736-1.523,2.15-2.313,2.15c-1.305,0-1.827-0.891-2.259-1.577l-2.786-4.4c-0.295-0.468-0.095-1.086,0.414-1.295l9.577-3.941c0.609-0.241,2.595-1.268,2.595-4.354c0-2.613-2.273-5.568-6.136-5.568c-1.477,0-3.409,0.795-3.409,0.795l-5.954,2.441c-1.773,0.732-1.773,1.404-1.773,1.764c0,0.018,0.086,1.591,2.045,1.591c0.2,0,0.805-0.091,1.636-0.432l5.909-2.445c1.227-0.505,3.136,0.15,3.136,2.023c0,1.027-0.595,1.395-1.495,1.763l-3.677,1.518l-2.145,0.886c-1.214,0.5-2.636,0.777-3.591,0.777c-3.863,0-6.363-2.663-6.363-5.681c0-1.859,0.795-4.404,4.591-5.963c0,0,0,0,2.059-0.845c0.859-0.359,2.077-0.859,3.804-1.573c0.559-0.232,1.123-0.464,1.859-0.641c0.745-0.177,1.659-0.295,2.913-0.295c7.272,0,11.136,5.454,11.136,9.886C38.181,26.023,36.34,28.291,34.772,29.527z"
                ></path>
              </svg>
            </div>
          </div>
        </div>
      </section>

      <!-- ================= SECTION: BIO ================= -->
      <section class="bio-section grid-area-bio">
        <p class="bio-text" style="white-space: pre-line;">
          {bioText}
        </p>
        <p class="bio-quote">
          <strong>{bioQuote}</strong>
        </p>
        <div class="bio-badges">
          <div class="info-badge">DIRECTION</div>
          <div class="info-badge">MOTION DESIGN</div>
        </div>
      </section>

      <section class="bio-section grid-area-window">
        <InfoWindow />
      </section>

      <!-- ================= SECTION: VALUE ================= -->
      <div id="value" class="bottom-banners">
        <div class="value-header-row">
          <PageDecorBanner
            id="banner-value"
            text="VALUE"
            variant="secondary"
            noMargin
          />
          <div class="banner-empty-filler" aria-hidden="true">
            <div class="symbol-circle"></div>
            <div class="symbol-cross"></div>
          </div>
        </div>

        <div class="value-cards-layout">
          {
            valueCards.map((card) => (
              <article class={`v-card v-card--${card.variant}`}>
                <header class="v-card__header" />
                <div class="v-card__body">
                  <div class="v-card__number-banner">
                    <span class="v-card__number">{card.id}</span>
                  </div>
                  <h4 class="v-card__title">{card.title}</h4>
                  <p class="v-card__desc">{card.desc}</p>
                </div>
              </article>
            ))
          }
        </div>

        <div id="experiences" class="value-conclusion">
          <div class="value-header-row">
            <PageDecorBanner
              id="banner-experiences"
              text="Experiences and Collaboration"
              variant="secondary"
              noMargin
            />
            <div class="banner-empty-filler" aria-hidden="true">
              <div class="symbol-circle"></div>
              <div class="symbol-cross"></div>
            </div>
          </div>
          <div class="collab-dropdown-list">
            {
              COLLAB_KEYS.map((catKey) => {
                const items = experiencesData.filter(
                  (e) => e.category === catKey,
                );
                if (items.length === 0) return null;

                const displayLabel = ENUM_MAP[catKey];

                return (
                  <details class="collab-dropdown" open>
                    <summary class="collab-cta">
                      <span class="collab-cta__text">{displayLabel}</span>
                      <PlayIcon class="collab-cta__icon collab-dropdown__icon" />
                    </summary>
                    <div class="collab-dropdown__content">
                      {items.map((item) => (
                        <div class="collab-item">
                          {item.year && (
                            <span class="collab-item__year">{item.year}</span>
                          )}
                          <p class="collab-item__desc">{item.description}</p>
                        </div>
                      ))}
                    </div>
                  </details>
                );
              })
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* ==========================================================
                        GLOBAL & UTILITIES
    ========================================================== */

  .banner-spacing {
    margin-top: var(--spacing-8);
  }
  .banner-headers {
    display: flex;
    flex-direction: column;
  }

  .page-content {
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  /* ==========================================================
                CLASS VARIANTS (CLEAN ARCHITECTURE)
    ========================================================= */
  .sidebar-nav {
    display: none;
  }

  .tool-card--ae {
    --brand-color: #ff6b9e;
  }
  .tool-card--ai {
    --brand-color: #ff9b6a;
  }
  .tool-card--ps {
    --brand-color: #005b6e;
  }
  .tool-card--custom {
    --brand-color: #046277;
    --card-bg: #fa729d;
    --icon-color: #f2f2f9;
  }

  .v-card--movie {
    --card-head-bg: var(--color-primary);
    --card-banner-bg: var(--color-secondary-light);
    --card-dot-bg: var(--color-secondary-light);
  }
  .v-card--illust {
    --card-head-bg: var(--color-secondary-light);
    --card-banner-bg: var(--color-secondary-light);
    --card-dot-bg: var(--color-accent-badge);
  }
  .v-card--design {
    --card-head-bg: var(--color-secondary-light);
    --card-banner-bg: var(--color-secondary-light);
    --card-dot-bg: var(--color-accent-badge);
  }

  /* ==========================================================
                        SECTION: VALUE
    ========================================================= */
  .bottom-banners {
    --filler-h: 50px;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: minmax(var(--filler-h), auto) auto auto auto;
    width: 100%;
    margin-top: var(--spacing-10);
  }

  .value-header-row {
    grid-column: 1 / -1;
    display: flex;
    align-items: stretch;
    gap: var(--spacing-4);
    width: 100%;
    min-height: var(--filler-h);
    height: auto;
  }

  .value-header-row > :global(.page-decor-banner) {
    flex: 1 1 0%;
    width: 0;
    min-width: 0;
    height: auto;
    min-height: 100%;
  }

  @media (max-width: 767px) {
    .value-header-row
      > :global(.page-decor-banner)
      :global(.page-decor-banner__text) {
      justify-content: flex-start;
      white-space: normal;
      text-align: left;
      padding-top: var(--spacing-4);
      padding-bottom: var(--spacing-4);
      line-height: 1.4;
    }
  }

  .banner-empty-filler {
    flex: 0 0 auto;

    --symbol-size: 48px;
    --cross-length: 44px;
    --symbol-thickness: 12px;
    --border-cross: 8px;
    --checker-h: var(--symbol-size);
    --checker-cell: calc(var(--checker-h) / 1.5);
    --checker-w: calc(var(--checker-cell) * 1.5);
    --top-gap: 6px;
    --block-ratio: 1.8;

    display: none;
    flex-direction: row;
    align-items: center;
    gap: var(--top-gap);
    padding-left: var(--top-gap);
  }

  .banner-empty-filler > .symbol-circle {
    order: 1;
    width: var(--symbol-size);
    height: var(--symbol-size);
    border: var(--symbol-thickness) solid var(--color-primary);
    border-radius: var(--radius-pill);
    flex-shrink: 0;
  }

  .banner-empty-filler > .symbol-cross {
    order: 2;
    width: var(--symbol-size);
    height: var(--symbol-size);
    position: relative;
    flex-shrink: 0;
  }

  .banner-empty-filler > .symbol-cross::before,
  .banner-empty-filler > .symbol-cross::after {
    content: "";
    position: absolute;
    width: var(--cross-length);
    height: var(--symbol-thickness);
    background-color: var(--color-primary);
    border: var(--border-cross) solid var(--color-primary);
    top: 50%;
    left: 50%;
  }

  .banner-empty-filler > .symbol-cross::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .banner-empty-filler > .symbol-cross::after {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .banner-empty-filler::before {
    content: "";
    order: 3;
    flex: 0 0 auto;
    width: clamp(30px, 8vw, 80px);
    min-width: calc(var(--checker-h) * var(--block-ratio));
    height: var(--checker-h);
    background-color: var(--color-primary);
  }

  .banner-empty-filler::after {
    content: "";
    order: 4;
    width: var(--checker-w);
    height: var(--checker-h);
    background-color: var(--bg-primary);

    --c: var(--color-primary);
    background-image:
      linear-gradient(
        45deg,
        var(--c) calc(25% + 0.5px),
        transparent calc(25% + 0.5px),
        transparent calc(75% - 0.5px),
        var(--c) calc(75% - 0.5px)
      ),
      linear-gradient(
        45deg,
        var(--c) calc(25% + 0.5px),
        transparent calc(25% + 0.5px),
        transparent calc(75% - 0.5px),
        var(--c) calc(75% - 0.5px)
      );
    background-size: calc(100% / 1.5) calc(100% / 1.5);
    background-repeat: repeat;
    background-position:
      calc(var(--checker-cell) / 2) 0,
      var(--checker-cell) calc(var(--checker-cell) / 2);
    margin-left: calc((var(--checker-cell) / -2) - var(--top-gap));
    flex-shrink: 0;
  }

  /* VALUE CARDS */
  .value-cards-layout {
    grid-column: 1 / -1;
    grid-row: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8);
    margin-top: var(--spacing-10);
    width: 100%;
  }
  .v-card {
    border: var(--border-width-sm) solid var(--color-secondary-darker);
    border-radius: var(--spacing-3);
    background-color: var(--bg-secondary);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .v-card__header {
    height: 2rem;
    background-color: var(--card-head-bg);
    border-bottom: var(--border-width-sm) solid var(--color-secondary-darker);
    display: flex;
    align-items: center;
    padding: 0 var(--spacing-2);
    flex-shrink: 0;
  }
  .v-card__header::before {
    content: "";
    display: block;
    width: 1rem;
    height: 1rem;
    background-color: var(--card-dot-bg);
    border: 2px solid var(--color-secondary-darker);
    border-radius: 50%;
  }

  .v-card__body {
    padding: var(--spacing-6) var(--spacing-4);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex-grow: 1;
    justify-content: center;
  }
  .v-card__number-banner {
    --checker-cell: 16px;
    width: 100%;
    height: 1.5rem;
    background-color: var(--card-banner-bg);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing-4);
    flex-shrink: 0;
  }
  .v-card__number-banner::before,
  .v-card__number-banner::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2rem;
    background: repeating-conic-gradient(
        var(--bg-secondary) 0 90deg,
        transparent 0 180deg
      )
      0 0 / 50% calc(100% / 1.5);
  }
  .v-card__number-banner::before {
    left: 0;
  }
  .v-card__number-banner::after {
    right: 0;
  }
  .v-card__number {
    font-size: var(--text-lg);
    font-weight: 900;
    color: var(--color-secondary-darker);
    line-height: 1;
    position: relative;
    z-index: 2;
  }
  .v-card__title {
    font-size: var(--text-xl);
    font-weight: 900;
    color: var(--color-secondary-darker);
    margin: 0 0 var(--spacing-2) 0;
    letter-spacing: 0.05em;
  }
  .v-card__desc {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-secondary-dark);
    margin: 0;
    line-height: 1.5;
  }

  /* ==========================================================
                        VALUE: CONCLUSION BLOCK
    ========================================================= */
  .value-conclusion {
    grid-column: 1 / -1;
    grid-row: 3;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
    margin-top: var(--spacing-8);
    padding: var(--spacing-6) var(--spacing-4);
    border-radius: var(--spacing-2);
  }

  .collab-dropdown-list {
    grid-column: 1 / -1;
    grid-row: 4;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
    margin-top: var(--spacing-8);
    width: 100%;
    max-width: var(--content-max-width, 75rem);
  }

  .collab-dropdown {
    justify-self: start;
    width: 100%;
  }

  .collab-cta {
    container-type: inline-size;
    display: grid;
    --icon-size: clamp(16px, 3.5vw, 28px);
    grid-template-columns: var(--icon-size) minmax(0, 1fr) var(--icon-size);
    align-items: center;
    gap: clamp(8px, 2vw, var(--spacing-4));
    width: min(calc(100% - 10px), 450px);
    padding: clamp(6px, 1.5vw, var(--spacing-2))
      clamp(12px, 3vw, var(--spacing-4));

    background: var(--color-primary);
    border: 4px solid var(--color-secondary-dark);
    box-shadow: 5px 8px 0px #7ee6fa;
    border-radius: 20px;
    overflow: hidden;

    text-decoration: none;
    transition:
      box-shadow 0.15s ease,
      transform 0.15s ease;
    cursor: pointer;
    list-style: none;
  }

  .collab-cta::-webkit-details-marker {
    display: none;
  }

  .collab-cta:active {
    transform: translate(2px, 3px);
    box-shadow: 3px 5px 0px #7ee6fa;
  }

  .collab-cta:hover {
    opacity: 0.85;
  }

  .collab-cta__text {
    grid-column: 2;
    text-align: center;
    color: var(--bg-secondary);
    font-size: clamp(14px, 4.5cqw, var(--text-xl));
    font-weight: 900;
    letter-spacing: 0.02em;
    white-space: nowrap;
    line-height: 1;
    transform: translateY(-2px);
  }

  .collab-cta :global(.collab-cta__icon) {
    grid-column: 3;
    justify-self: center;
    width: var(--icon-size);
    height: var(--icon-size);
    color: var(--bg-secondary);
    flex-shrink: 0;
  }

  .collab-dropdown__icon {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .collab-dropdown[open] .collab-dropdown__icon {
    transform: rotate(90deg);
  }

  .collab-dropdown__content {
    margin-top: var(--spacing-6);
    animation: DropdownSlideIn 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    transform-origin: top;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  @keyframes DropdownSlideIn {
    from {
