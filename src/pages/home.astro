---
import Layout from "../layouts/Layout.astro";
import KimeSplash from "../components/KimeSplash.astro";
import CyberRibbon from "../components/CyberRibbon.astro";
import PageDecorBanner from "../components/PageDecorBanner.astro";
import KimeyuIcon from "../components/icons/KimeyuIcon.astro";
import { fetchVideos, fetchArtworks, fetchSiteProfile } from "../lib/hygraph";

// FETCH HERO SLIDER DATA
const [allVideos, allArtworks, profileData] = await Promise.all([
  fetchVideos(),
  fetchArtworks(),
  fetchSiteProfile().catch(() => null),
]);

// Social Links Fallbacks
const discordLink = profileData?.linkDiscord || "https://discord.com/users/683574461147906078";
const discordHandle = profileData?.handleDiscord || "kimeyu_39";

const xLink = profileData?.linkX || "https://twitter.com/Kimeru2001";
const xHandle = profileData?.handleX || "@Kimeru2001";

const fbLink = profileData?.linkFacebook || "https://facebook.com/kimerukirisu/";
const fbHandle = profileData?.handleFacebook || "facebook.com/kimerukirisu/";

const emailLink = profileData?.linkEmail || "mailto:kimeyukawa@gmail.com";
const emailHandle = profileData?.handleEmail || "kimeyukawa@gmail.com";

// Extract newest item per category (Zero bloat: only storing strings)
const vMusic = allVideos.find((v) => v.category?.name?.includes("MusicVideos"));
const vDebut = allVideos.find((v) => v.category?.name?.includes("Debut"));
const aIllust = allArtworks.find((a) => a.category?.name === "Illustration");

const heroSlides = [
  vMusic
    ? {
        url:
          vMusic.imageEmbed?.[0]?.heroUrl ||
          vMusic.thumbnail?.heroUrl ||
          vMusic.thumbnail?.fullUrl ||
          vMusic.thumbnail?.url,
        link: vMusic.linkOriginal || `/work/motions/${vMusic.slug}`,
        target: "_blank",
      }
    : null,
  vDebut
    ? {
        url:
          vDebut.imageEmbed?.[0]?.heroUrl ||
          vDebut.thumbnail?.heroUrl ||
          vDebut.thumbnail?.fullUrl ||
          vDebut.thumbnail?.url,
        link: vDebut.linkOriginal || `/work/motions/${vDebut.slug}`,
        target: "_blank",
      }
    : null,
  aIllust
    ? {
        url:
          aIllust.image?.heroUrl ||
          aIllust.image?.fullUrl ||
          aIllust.image?.url,
        link: aIllust.linkPixiv || `/work/artwork/`,
        target: "_blank",
      }
    : null,
].filter((s): s is { url: string; link: string; target: string } =>
  Boolean(s && s.url),
);

// Extract FEATURED videos
const featuredVideos = allVideos.filter((v) => v.isFeatured).slice(0, 6);
---

<Layout title="kimeyu.work">
  <div class="contact-page-wrapper">
    <KimeSplash />

    <!-- TOP RIBBON (ASCII generated SVG) -->
    <CyberRibbon />

    <div class="decor-ribbon" aria-hidden="true" style="margin-bottom: 2rem;">
      <div class="film-strip-bg">
        <div class="banner-strip" style="transform: translateY(-50%);"></div>
      </div>
    </div>

    <!-- Kimeyu Core Slogan -->
    <section class="contact-quote-block" aria-label="Kimeyu Slogan">
      <div class="quote-wrapper">
        <h2 class="quote-text">
          <span class="quote-line"
            >BUILT ON <span class="text-cyan">RHYTHM</span></span
          >
          <span class="quote-line"
            >DRIVEN BY <span class="text-pink">PRECISION</span></span
          >
        </h2>
      </div>
    </section>

    <!-- PICK UP WORKS BANNER -->
    <div class="decor-ribbon pickup-works-ribbon">
      <div class="ribbon-pickup-label">
        <span class="pickup-en">PICK-UP WORKS</span>
        <span class="pickup-jp">ピックアップ作品</span>
      </div>
      <nav class="ribbon-nav-dots" aria-label="Page Navigation">
        <button class="nav-dot nav-dot--active" aria-label="Section 1"></button>
        <button class="nav-dot" aria-label="Section 2"></button>
        <button class="nav-dot" aria-label="Section 3"></button>
        <button class="nav-dot" aria-label="Section 4"></button>
        <button class="nav-dot" aria-label="Section 5"></button>
      </nav>
      <div class="film-strip-bg" aria-hidden="true">
        <div class="banner-strip banner-strip--inverted"></div>
      </div>
    </div>

    <!-- FEATURED SECTION -->
    <section class="featured-works-section" aria-label="Featured Works">
      <div class="featured-header">
        <h2 class="featured-title">FEATURED</h2>
      </div>

      <div class="featured-cards-container">
        {
          featuredVideos.map((video, index) => (
            <article
              class={`featured-card ${index === 0 ? "featured-card--new" : ""}`}
            >
              <a
                href={`/work/motions/${video.slug}`}
                class="card-thumb"
                style={`background-image: url('${video.thumbnail.url}'); background-size: cover; background-position: center; display: block;`}
                aria-label={`Watch ${video.title}`}
              >
                {index === 0 && <span class="card-badge">NEW!</span>}
              </a>
              <div class="card-info">
                <div class="card-info__text">
                  <h3 class="card-title">{video.title}</h3>
                  <p class="card-sub">{video.nameArtist}</p>
                </div>
                <a
                  href={`/work/motions/${video.slug}`}
                  class="card-play-btn"
                  aria-label={`Play ${video.title}`}
                />
              </div>
              <div class="card-tags">
                <span class="tag-cat">
                  {video.category?.name?.toUpperCase() || "MOTION GRAPHICS"}
                </span>
                <span class="tag-status">
                  {video.category?.visibility === "Private"
                    ? "Private"
                    : "Public"}
                </span>
              </div>
            </article>
          ))
        }
      </div>

      <div class="featured-footer-row">
        <div class="featured-pagination" aria-label="Featured Pagination">
          <button class="featured-dot featured-dot--active" aria-label="1"
          ></button>
        </div>

        <PageDecorBanner
          href="/work/motions"
          text="SEE MORE "
          checkerPosition="both"
          checkerPositionPc="start"
          compact={true}
        />
      </div>
    </section>

    <!-- CONTACT SECTION -->
    <section class="contact-entry-section">
      <div class="contact-huge-row">
        <div class="contact-huge-title" aria-hidden="true">CONTACT</div>

        <div class="contact-huge-right" aria-hidden="true">
          <div class="cht-right-top">
            <div class="cht-symbol-circle"></div>
            <div class="cht-symbol-cross"></div>
          </div>

          <div class="cht-right-bottom">
            <div class="cht-mini-squares"></div>
            <div class="cht-kimeyu-wrapper">
              <KimeyuIcon class="cht-kimeyu" width={100} height={20} />
            </div>
          </div>
        </div>
      </div>

      <div class="contact-entry-ribbon" aria-hidden="true">
        <span class="ribbon-dot"></span>
        <span class="ribbon-dot"></span>
        <span class="ribbon-dot"></span>
        <span class="ribbon-dot"></span>
        <span class="ribbon-dot ribbon-dot--pink"></span>
      </div>

      <div class="contact-entry-main">
        <h2 class="contact-entry-heading">
          CONTACT<br /><span class="jp-sub">コンタクト</span>
        </h2>

        <ul class="contact-instructions">
          <li class="instruction-strong">
            Please include as much information as possible
          </li>
          <li>Details of your request</li>
          <li>Desired delivery date</li>
          <li>Budget (to the extent known)</li>
          <li>
            Contact method (if you would prefer to be contacted via Discord,
            Facebook, etc. instead of email, please include your ID, profile
            link, username etc.)
          </li>
          <li>And any other remarks.</li>
        </ul>

        <div class="contact-pill-grid">
          <!-- Discord -->
          <div class="social-pill-wrapper">
            <a
              href={discordLink}
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill__link"
              aria-label="Kimeyu Discord"
            >
              <div class="social-pill__icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"
                  ></path></svg
                >
              </div>
              <div class="social-pill__content">
                <span class="social-pill__handle">{discordHandle}</span>
                <span class="social-pill__platform">DISCORD</span>
              </div>
            </a>
            <button
              class="social-copy btn-copy"
              data-copy-text={discordHandle}
              aria-label="Copy Discord"
            >
              <svg viewBox="0 0 24 24"
                ><path
                  fill="currentColor"
                  d="M16 1H4C2.9 1 2 1.9 2 3v14h2V3h12V1zm3 4H8C6.9 5 6 5.9 6 7v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"
                ></path></svg
              >
            </button>
          </div>

          <!-- X (Twitter) -->
          <div class="social-pill-wrapper">
            <a
              href={xLink}
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill__link"
              aria-label="Kimeyu X"
            >
              <div class="social-pill__icon" style="padding: 10px;">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                  ></path></svg
                >
              </div>
              <div class="social-pill__content">
                <span class="social-pill__handle">{xHandle}</span>
                <span class="social-pill__platform">X</span>
              </div>
            </a>
            <button
              class="social-copy btn-copy"
              data-copy-text={xHandle}
              aria-label="Copy X"
            >
              <svg viewBox="0 0 24 24"
                ><path
                  fill="currentColor"
                  d="M16 1H4C2.9 1 2 1.9 2 3v14h2V3h12V1zm3 4H8C6.9 5 6 5.9 6 7v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"
                ></path></svg
              >
            </button>
          </div>

          <!-- Facebook -->
          <div class="social-pill-wrapper">
            <a
              href={fbLink}
              target="_blank"
              rel="noopener noreferrer"
              class="social-pill__link"
              aria-label="Kimeyu Facebook"
            >
              <div class="social-pill__icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103v3.328h-1.011c-2.122 0-2.56.778-2.56 2.47v1.657h3.646l-.508 3.666h-3.138v7.98h-3.75z"
                  ></path></svg
                >
              </div>
              <div class="social-pill__content">
                <span class="social-pill__handle"
                  >{fbHandle}</span
                >
                <span class="social-pill__platform">FACEBOOK//MESSSENGER</span>
              </div>
            </a>
            <button
              class="social-copy btn-copy"
              data-copy-text={fbHandle}
              aria-label="Copy Facebook"
            >
              <svg viewBox="0 0 24 24"
                ><path
                  fill="currentColor"
                  d="M16 1H4C2.9 1 2 1.9 2 3v14h2V3h12V1zm3 4H8C6.9 5 6 5.9 6 7v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"
                ></path></svg
              >
            </button>
          </div>

          <!-- Email -->
          <div class="social-pill-wrapper">
            <a
              href={emailLink}
              class="social-pill__link"
              aria-label="Kimeyu Mail"
            >
              <div class="social-pill__icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zM20 6H4l8 5 8-5zM20 18V8.2l-8 5-8-5V18h16z"
                  ></path></svg
                >
              </div>
              <div class="social-pill__content">
                <span class="social-pill__handle">{emailHandle}</span>
                <span class="social-pill__platform">GMAIL</span>
              </div>
            </a>
            <button
              class="social-copy btn-copy"
              data-copy-text={emailHandle}
              aria-label="Copy Email"
            >
              <svg viewBox="0 0 24 24"
                ><path
                  fill="currentColor"
                  d="M16 1H4C2.9 1 2 1.9 2 3v14h2V3h12V1zm3 4H8C6.9 5 6 5.9 6 7v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"
                ></path></svg
              >
            </button>
          </div>
        </div>
      </div>

      <!-- STRAIGHT BANNER STRIP -->
      <div class="contact-straight-strip-wrapper" aria-hidden="true"></div>
    </section>
  </div>
</Layout>

<script>
  const initCopyEngine = () => {
    const copyBtns = document.querySelectorAll<HTMLButtonElement>(".btn-copy");

    if (!copyBtns.length) return;

    copyBtns.forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.preventDefault();

        const text = btn.dataset.copyText;

        if (!text) {
          console.error("Clipboard Error: Missing data-copy-text");
          return;
        }

        try {
          if (!navigator.clipboard) {
            throw new Error(
              "Clipboard API bị chặn. Phải chạy trên HTTPS hoặc Localhost.",
            );
          }

          await navigator.clipboard.writeText(text);

          const originalHtml = btn.innerHTML;
          btn.innerHTML = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>`;

          setTimeout(() => {
            btn.innerHTML = originalHtml;
          }, 1500);
        } catch (err) {
          console.error("Failed to write to Memory/Clipboard:", err);
        }
      });
    });
  };

  initCopyEngine();

  document.addEventListener("astro:page-load", initCopyEngine);
</script>
<style>
  /* ==============================================
     HERO SLIDER (Zero Layout Blueprint)
     ============================================== */
  hero-slider {
    display: contents;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .contact-page-wrapper {
    --block-w: clamp(120px, 20vw, 320px);
    --hero-offset-x: 0px;
    position: relative;
    width: 100%;
    min-height: max(100vh, 800px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .top-decor-banner,
  .bottom-decor-banner {
    --h: clamp(40px, 6vw, 80px);
    --t-size: calc(var(--h) * 0.325);
    --slant-w: calc(var(--h) * 0.3);
    --cap-w: calc(var(--h) * 0.9375);
    --pink-len: calc(var(--h) * 1.5);

    display: flex;
    align-items: stretch;
    position: absolute;
    left: 0;
    z-index: 12;
    width: 100%;
    max-width: none;
    height: var(--h);
  }

  .top-decor-banner {
    transform: scaleX(-1);
    top: 0;
    margin: 0;
  }

  .bottom-decor-banner {
    bottom: 0;
    margin: 0;
  }

  .top-decor-banner::after,
  .bottom-decor-banner::after {
    content: "";
    flex: 1;
    height: var(--t-size);
    --cell: calc(var(--t-size) / 1.5);

    --chk: conic-gradient(
      var(--base-white) 90deg,
      transparent 90deg 180deg,
      var(--base-white) 180deg 270deg,
      transparent 270deg
    );

    background-image:
      var(--chk), var(--chk), var(--chk), var(--chk), var(--chk),
      linear-gradient(
        to right,
        var(--color-secondary-light) calc(100% - var(--pink-len)),
        var(--color-primary) 0
      );

    background-size:
      var(--cell) var(--cell),
      var(--cell) var(--cell),
      var(--cell) var(--cell),
      var(--cell) var(--cell),
      var(--cell) var(--cell),
      100% 100%;

    background-position:
      0 0,
      calc(var(--cell)) 0,
      calc(100% - var(--pink-len)) 0,
      100% 0,
      calc(100% - var(--cell)) 0,
      0 0;

    background-repeat:
      repeat-y, repeat-y, repeat-y, repeat-y, repeat-y, no-repeat;
  }

  .top-decor-banner::after {
    align-self: flex-start;
  }

  .bottom-decor-banner::after {
    align-self: flex-end;
  }

  .top-decor-banner__cap,
  .bottom-decor-banner__cap {
    background-color: var(--base-white);
    width: var(--cap-w);
    flex-shrink: 0;
    order: -1;
  }

  .top-decor-banner::before,
  .bottom-decor-banner::before {
    content: "";
    --c-size: calc(var(--h) / 1.5);
    width: calc(var(--c-size) * 1.5);
    background-color: var(--color-secondary-light);
    background-image: conic-gradient(
      transparent 25%,
      var(--base-white) 0 50%,
      transparent 0 75%,
      var(--base-white) 0
    );
    background-size: var(--c-size) var(--c-size);
    background-position: 0 0;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .top-decor-banner__body {
    flex: 0 1 48%;
    clip-path: polygon(
      0 0,
      100% 0,
      100% var(--t-size),
      calc(100% - var(--slant-w)) 100%,
      0 100%
    );
    background-color: var(--color-secondary-light);
    min-width: 0;
  }

  .bottom-decor-banner__body {
    flex: 0 1 48%;
    clip-path: polygon(
      0 0,
      calc(100% - var(--slant-w)) 0,
      100% calc(100% - var(--t-size)),
      100% 100%,
      0 100%
    );
    background-color: var(--color-secondary-light);
    min-width: 0;
  }

  @media (max-width: 1023px) {
    .top-decor-banner,
    .bottom-decor-banner {
      width: 100%;
    }
  }

  /* ==============================================
      HERO SHOWCASE
      ============================================== */
  .contact-hero-showcase {
    --cross-gap: clamp(8px, 1.5vw, 20px);
    --ribbon-thick: clamp(60px, 8vw, 100px);
    --ribbon-gap: clamp(16px, 2.5vw, 40px);

    --active-w-ratio: 0.82;

    --hero-bg: #eaeff6;
    --hero-h: calc(100vw * var(--active-w-ratio) * 9/16);
    --diamond-size: clamp(300px, 45vw, 600px);
    --strip-w-border: clamp(8px, 1.2vw, 16px);
    --grid-banner-bg: #ffc0db;

    position: relative;
    width: 100%;
    height: var(--hero-h);

    --b-h: clamp(40px, 6vw, 80px);
    --b-t: calc(var(--b-h) * 0.325);
    overflow: hidden;

    --grid-c: var(--color-secondary-light);
    --decor-s: clamp(25px, 3.5vw, 50px);

    --decor-gap-r: calc(
      100vw * (1 - var(--active-w-ratio)) - (var(--decor-s) * 2)
    );
    --decor-gap-b: clamp(20px, 3vw, 50px);

    background-color: var(--hero-bg);
  }

  .contact-hero-showcase::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: calc(var(--diamond-size) * 0.9);
    height: clamp(60px, 8vw, 110px);
    background-color: var(--color-secondary-light);
    border-bottom: var(--strip-w-border) solid var(--base-white);
    border-right: var(--strip-w-border) solid var(--base-white);
    box-shadow: 4px 4px 20px rgba(0, 0, 0, 0.1);
    background-image: url("/patterns/kimeyu-tile-cyan.svg");
    background-size: auto 100%;
    background-repeat: repeat-x;
    background-position: var(--spacing-4) center;
    z-index: 3;
    border-bottom-right-radius: 3px;
    transform-origin: top left;
    transform: translate(
        calc(var(--diamond-size) * -0.2),
        calc(var(--diamond-size) * 0.2)
      )
      rotate(-45deg);
  }

  .contact-hero-showcase::after {
    content: "";
    position: absolute;
    bottom: var(--decor-gap-b);
    right: var(--decor-gap-r);
    width: var(--decor-s);
    height: var(--decor-s);
    background-color: var(--grid-c);
    --w: var(--base-white);

    background-image:
      linear-gradient(var(--w), var(--w)), linear-gradient(var(--w), var(--w)),
      linear-gradient(var(--w), var(--w));
    background-position:
      right calc(var(--decor-s) * 0.12) top calc(var(--decor-s) * 0.5),
      right calc(var(--decor-s) * 0.12) top 0,
      right calc(var(--decor-s) * 0.44) top calc(var(--decor-s) * 0.16);
    background-size:
      80% 25%,
      24% 50%,
      24% 25%;
    background-repeat: no-repeat;
    z-index: 15;
    pointer-events: none;
  }

  .hero-layer-over {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    overflow: hidden;
    container-type: inline-size;
  }

  .hero-layer-over::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    background:
      linear-gradient(var(--grid-c), var(--grid-c)) right var(--decor-gap-r)
        bottom calc(var(--decor-s) * 3 + var(--decor-gap-b)) / var(--decor-s)
        var(--decor-s) no-repeat,
      linear-gradient(var(--grid-c), var(--grid-c)) right var(--decor-gap-r)
        bottom calc(var(--decor-s) + var(--decor-gap-b)) /
        calc(var(--decor-s) * 3) calc(var(--decor-s) * 2) no-repeat,
      linear-gradient(var(--grid-c), var(--grid-c)) right
        calc(var(--decor-s) + var(--decor-gap-r)) bottom var(--decor-gap-b) /
        var(--decor-s) var(--decor-s) no-repeat,
      linear-gradient(var(--grid-c), var(--grid-c)) right
        calc(var(--decor-s) * 3 + var(--decor-gap-r)) bottom
        var(--decor-gap-b) / var(--decor-s) var(--decor-s) no-repeat;
  }

  /* ==============================================
     ART CAROUSEL (Otoiro Left-Aligned Config)
     ============================================== */
  .art-carousel-track {
    display: flex;
    align-items: center;
    height: 100%;
    width: 100%;

    --slide-w: calc(100cqw * var(--active-w-ratio));
    gap: 0;

    will-change: transform;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    transform: translateX(calc(var(--idx, 0) * var(--slide-w) * -1));
  }

  .art-carousel-slide {
    flex: 0 0 var(--slide-w);
    height: 100%;
    max-height: 100%;

    background-color: transparent;
    border-radius: 0;
    box-shadow: none;

    opacity: 1;
    transform: none;
    transition: filter 0.8s ease;
  }

  .slide-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    -webkit-user-drag: none;
  }

  .slide-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    -webkit-user-drag: none;
  }

  .art-carousel-slide:not(.is-active) {
    filter: brightness(0.4) saturate(0.8);
    pointer-events: none;
  }

  .art-carousel-slide.is-active {
    z-index: 5;
  }

  @media (max-width: 768px) {
    .contact-hero-showcase {
      --active-w-ratio: 1;

      --hero-h: calc(100vw * 4/5);

      --decor-gap-r: clamp(10px, 4vw, 25px);
    }
  }

  /* ==============================================
     MEDIA PLAYER WIDGET
     ============================================== */
  .kime-media-player {
    width: 100%;
    max-width: 650px;
    margin: var(--spacing-12) auto var(--spacing-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-10);
    padding: 0 var(--spacing-6);
  }

  @media (min-width: 769px) {
    .kime-media-player {
      display: none;
    }
  }

  .kime-media-track {
    width: 100%;
    height: 10px;
    background-color: #dcdcdc;
    border-radius: 5px;
    position: relative;
    display: flex;
    align-items: center;
    --progress: 0%;
    --track-dur: 0ms;
    cursor: grab;
    touch-action: pan-y;
  }

  .kime-media-track:active {
    cursor: grabbing;
  }

  .kime-media-track::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: var(--progress);
    background-color: var(--color-secondary-light);
    border-radius: 5px;
    transition: width var(--track-dur) linear;
  }

  .kime-media-track::after {
    content: "";
    position: absolute;
    width: 32px;
    height: 16px;
    background-color: var(--color-primary-light);
    border-radius: 8px;
    left: var(--progress);
    top: 50%;
    transform: translate(-50%, -50%);
    transition: left var(--track-dur) linear;
  }

  .kime-media-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(60px, 15vw, 120px);
  }

  .kime-media-btn {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    height: 30px;
    transition: transform 0.2s cubic-bezier(0.18, 0.89, 0.32, 1.28);
  }

  .kime-media-btn:hover {
    transform: scale(1.1);
  }

  /* PAUSE */
  .kime-media-btn--pause {
    width: 20px;
  }
  .kime-media-btn--pause::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 7px;
    height: 100%;
    background-color: var(--color-primary-light);
    border-radius: 1px;
    box-shadow: 13px 0 0 var(--color-primary-light);
    transition: all 0.2s ease;
  }
  .kime-media-btn--pause.paused::before {
    background-color: transparent;
    box-shadow: none;
    border-top: 15px solid transparent;
    border-bottom: 15px solid transparent;
    border-left: 20px solid var(--color-primary-light);
    width: 0;
    height: 0;
  }

  /* PREV */
  .kime-media-btn--prev {
    width: 46px;
  }
  .kime-media-btn--prev::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 7px;
    height: 100%;
    background-color: var(--color-primary-light);
    border-radius: 1px;
    box-shadow: 13px 0 0 var(--color-primary-light);
  }
  .kime-media-btn--prev::after {
    content: "";
    position: absolute;
    right: 0;
    top: 0;
    width: 0;
    height: 0;
    border-top: 15px solid transparent;
    border-bottom: 15px solid transparent;
    border-right: 20px solid var(--color-primary-light);
  }

  /* NEXT */
  .kime-media-btn--next {
    width: 46px;
  }
  .kime-media-btn--next::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 0;
    height: 0;
    border-top: 15px solid transparent;
    border-bottom: 15px solid transparent;
    border-left: 20px solid var(--color-primary-light);
  }
  .kime-media-btn--next::after {
    content: "";
    position: absolute;
    left: 26px;
    top: 0;
    width: 7px;
    height: 100%;
    background-color: var(--color-primary-light);
    border-radius: 1px;
    box-shadow: 13px 0 0 var(--color-primary-light);
  }

  /* ==============================================
     SLOGAN QUOTE BLOCK
     ============================================== */
  .contact-quote-block {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: clamp(var(--spacing-16), 15vw, var(--spacing-36)) var(--spacing-4);
    background-color: var(--hero-bg);
    width: 100%;
  }

  .quote-wrapper {
    position: relative;
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: clamp(var(--spacing-6), 6vw, var(--spacing-12))
      clamp(var(--spacing-10), 10vw, var(--spacing-20));
  }

  .quote-wrapper::before,
  .quote-wrapper::after {
    content: "";
    position: absolute;
    --q-w: clamp(10px, 2.5vw, 20px);
    --q-h: clamp(28px, 5vw, 45px);
    --q-gap: calc(var(--q-w) * 1.5);
    width: var(--q-w);
    height: var(--q-h);
    transform: skewX(-15deg);
  }

  .quote-wrapper::before {
    top: 0;
    left: 0;
    background-color: var(--color-secondary-bright);
    box-shadow: var(--q-gap) 0 0 var(--color-secondary-bright);
  }
  .quote-wrapper::after {
    bottom: -15%;
    right: var(--q-gap);
    background-color: var(--color-primary);
    box-shadow: var(--q-gap) 0 0 var(--color-primary);
  }

  .quote-text {
    font-size: clamp(1.4rem, 4.5vw, 3.8rem);
    font-weight: 900;
    font-family: var(--font-sans);
    color: var(--color-secondary-darker);
    text-align: center;
    line-height: 1.15;
    margin: 0;
    display: flex;
    flex-direction: column;
    letter-spacing: -0.01em;
  }
  .quote-text .text-cyan {
    color: var(--color-secondary-bright);
  }
  .quote-text .text-pink {
    color: var(--color-primary);
  }

  /* ==============================================
     INVERTED BANNER STRIP
     ============================================== */
  .decor-ribbon {
    --b-gap: clamp(4px, 1vw, 12px);
    --b-h-top: clamp(10px, 3vw, 28px);
    --b-h-bottom: clamp(20px, 5vw, 48px);
    --b-pad: clamp(12px, 2vw, 20px);
    --b-total-h: calc(
      var(--b-h-top) + var(--b-h-bottom) + var(--b-gap) + 2 * var(--b-pad)
    );
    --safe-edge: clamp(var(--spacing-6), 5vw, var(--spacing-12));

    position: relative;
    z-index: 5;
    width: 100%;
    height: var(--b-total-h);
    margin-top: var(--spacing-12);
    overflow: hidden;
  }

  @media (min-width: 80rem) {
    .decor-ribbon {
      --safe-edge: calc(50vw - 40rem + var(--spacing-12));
    }
  }

  .pickup-works-ribbon {
    --ui-h: clamp(28px, 4vw, 40px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--safe-edge);
    overflow: hidden;
  }

  .film-strip-bg {
    position: absolute;
    inset: 0 -10vw;
    z-index: 1;
    pointer-events: none;
  }

  .banner-strip {
    --gap: var(--b-gap);
    --h-top: var(--b-h-top);
    --h-bottom: var(--b-h-bottom);
    --pad: var(--b-pad);
    --sq-w: calc(var(--h-top) + var(--h-bottom) + var(--gap));
    --logo-w: calc(var(--h-bottom) * 4.8879);
    --margin-gap: clamp(8px, 4vw, 64px);
    --tile-w: calc(
      2 * var(--pad) + var(--sq-w) + var(--gap) + var(--logo-w) +
        var(--margin-gap)
    );
    --tile-h: calc(
      2 * var(--pad) + var(--h-top) + var(--gap) + var(--h-bottom)
    );

    position: absolute;
    top: 50%;
    left: -10vw;
    width: 200vw;
    height: var(--tile-h);
    transform-origin: 50vw center;

    background-color: var(--color-secondary-light);
    border-top: var(--border-width-md, 2px) solid var(--base-white);
    border-bottom: var(--border-width-md, 2px) solid var(--base-white);
    box-shadow: 0 4px 4px rgba(0, 0, 0, 0.12);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    -webkit-transform-style: preserve-3d;
    transform-style: preserve-3d;

    background-image: url("/patterns/kimeyu-tile-cyan.svg");
    background-size: var(--tile-w) var(--tile-h);
    background-repeat: repeat-x;
    background-position: 0 center;
  }

  .banner-strip--inverted {
    transform: translateY(-50%) rotate(0) scaleY(-1) translateZ(0);
    z-index: 1;
  }

  /* ==============================================
     PICK-UP WORKS LABEL
     ============================================== */
  .ribbon-pickup-label {
    position: relative;
    z-index: 5;
    background-color: var(--base-white);
    border: clamp(2px, 0.4vw, 3px) solid var(--color-secondary-darker);
    height: var(--ui-h);
    padding: 0 clamp(6px, 1.5vw, 24px);
    display: flex;
    align-items: center;
    gap: clamp(2px, 0.8vw, var(--spacing-3));
    white-space: nowrap;
    flex-shrink: 1;
    min-width: 0;
    overflow: hidden;
    box-sizing: border-box;
  }
  .pickup-en {
    font-size: clamp(0.55rem, 1.5vw, 1rem);
    font-weight: 900;
    color: var(--color-secondary-darker);
    letter-spacing: 0.5px;
  }
  .pickup-jp {
    font-size: clamp(0.45rem, 1.2vw, 0.8rem);
    font-weight: 900;
    color: var(--color-secondary-darker);
  }

  /* ==============================================
     NAVIGATION DOTS
     ============================================== */
  .ribbon-nav-dots {
    --dot-size: max(calc(var(--b-total-h) * 0.17), 13px);
    --dot-gap: max(calc(var(--b-total-h) * 0.095), 6px);
    --dot-border: clamp(2px, 0.4vw, 3px);
    --dot-pad: max(calc(var(--b-total-h) * 0.08), 6px);
    --checker-cell: calc((var(--dot-size) + 2 * var(--dot-pad)) / 3);
    --grid-w: calc(var(--checker-cell) * 7);
    --gap-to-grid: max(calc(var(--b-total-h) * 0.185), 14px);
    --grid-pad-left: clamp(24px, 4vw, 64px);

    position: absolute;
    left: var(--safe-edge);
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    gap: var(--dot-gap);

    padding: var(--dot-pad);
    border: none;
    padding-left: calc(
      var(--grid-pad-left) + var(--grid-w) + var(--gap-to-grid)
    );
    padding-right: clamp(24px, 4vw, 64px);
    overflow: hidden;
    isolation: isolate;
  }

  @media (max-width: 767px) {
    .ribbon-nav-dots {
      --dot-size: 14px;
      --dot-gap: 3px;
      --dot-border: 1.5px;
      --dot-pad: 3px;
      --grid-pad-left: 12px;
      --gap-to-grid: 6px;
      padding-right: 12px;
    }
  }

  @media (min-width: 1024px) {
    .ribbon-nav-dots {
      left: clamp(var(--spacing-12), 10vw, 15vw);
    }
  }
  @media (min-width: 80rem) {
    .ribbon-nav-dots {
      left: calc(50vw - 40rem + 15vw);
    }
  }

  .pickup-works-ribbon .ribbon-nav-dots {
    --dot-size: max(calc(var(--ui-h) * 0.55), 14px);
    --dot-gap: max(calc(var(--ui-h) * 0.25), 8px);
    --gap-to-grid: max(calc(var(--ui-h) * 0.3), 8px);
    --checker-cell: calc(var(--ui-h) / 3);

    position: relative;
    left: auto;
    top: auto;
    height: var(--ui-h);
    padding-top: 0;
    padding-bottom: 0;
    transform: none;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    .pickup-works-ribbon .ribbon-nav-dots {
      --dot-size: 11px;
      --dot-gap: 5px;
      --dot-border: 2px;
      --grid-w: calc(var(--checker-cell) * 3);
      --grid-pad-left: 10px;
      --gap-to-grid: 5px;
      padding-right: 10px;
      flex-shrink: 1;
      min-width: 0;
    }
  }

  .ribbon-nav-dots::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background-color: var(--base-white);

    -webkit-mask-image:
      linear-gradient(#000, #000), linear-gradient(#000, #000),
      var(--checker-mask-uri);
    mask-image:
      linear-gradient(#000, #000), linear-gradient(#000, #000),
      var(--checker-mask-uri);

    -webkit-mask-position:
      0 0,
      calc(var(--grid-pad-left) + var(--grid-w)) 0,
      var(--grid-pad-left) 0;
    mask-position:
      0 0,
      calc(var(--grid-pad-left) + var(--grid-w)) 0,
      var(--grid-pad-left) 0;

    -webkit-mask-size:
      var(--grid-pad-left) 100%,
      100% 100%,
      calc(var(--checker-cell) * 2) calc(var(--checker-cell) * 2);
    mask-size:
      var(--grid-pad-left) 100%,
      100% 100%,
      calc(var(--checker-cell) * 2) calc(var(--checker-cell) * 2);

    -webkit-mask-repeat: no-repeat, no-repeat, repeat;
    mask-repeat: no-repeat, no-repeat, repeat;
    transform: translateZ(0);
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .nav-dot {
    width: var(--dot-size);
    height: var(--dot-size);
    border-radius: 50%;
    border: var(--dot-border) solid var(--color-secondary-darker);
    background-color: var(--color-secondary-light);
    padding: 0;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .nav-dot:hover {
    transform: scale(1.15);
  }
  .nav-dot--active {
    background-color: var(--color-primary);
    border-color: var(--color-secondary-darker);
  }

  /* ==============================================
     FEATURED WORKS SECTION
     ============================================== */
  .featured-works-section {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-bottom: var(--spacing-12);
    z-index: 10;
  }

  .featured-header {
    width: 100%;
    background-color: var(--color-primary);
    padding: var(--spacing-16) 0 calc(var(--spacing-24) + 10vw) 0;
    display: flex;
    justify-content: flex-end;
    overflow: hidden;
    position: relative;
  }

  .featured-title {
    position: absolute;
    right: clamp(16px, 4vw, 40px);
    top: clamp(10px, 3vw, 40px);
    font-family: var(--font-sans);
    font-size: clamp(3rem, 12.5vw, 24rem);
    font-weight: 900;
    color: var(--base-gray-50);
    margin: 0;
    line-height: 0.8;
    letter-spacing: -0.02em;
    z-index: 1;
    white-space: nowrap;
  }

  .featured-cards-container {
    margin-top: clamp(-200px, -15vw, -80px); /* Negative margin responsive */
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
    justify-items: center;
    gap: clamp(var(--spacing-6), 6vw, var(--spacing-16));
    width: 100%;
    max-width: 1240px;
    padding: 0 clamp(16px, 4vw, 40px);
    position: relative;
    z-index: 2;
  }

  @media (max-width: 1023px) {
    .featured-card:nth-child(n + 4) {
      display: none !important;
    }
  }

  .featured-card {
    --c-border: 3px solid var(--color-secondary-darker);
    --c-pink-line: 4px solid var(--color-primary-light);
    display: flex;
    flex-direction: column;
    width: clamp(280px, 85vw, 360px);
    position: relative;
    align-items: center;
  }

  .card-thumb {
    width: calc(100% - 40px);
    aspect-ratio: 16/10;
    background-color: var(--base-white);
    border: var(--c-border);
    border-bottom: var(--c-pink-line);
    position: relative;
    z-index: 2;
  }

  .card-thumb::before {
    content: "";
    position: absolute;
    top: 10px;
    left: calc(100% + 10px);
    --decor-cell: 8px;
    --blocks-x: 3;
    --blocks-y: 3;
    width: calc(var(--decor-cell) * var(--blocks-x));
    height: calc(var(--decor-cell) * var(--blocks-y));
    background-color: var(--color-secondary-light);
  }

  .card-thumb::after {
    content: "";
    position: absolute;
    --decor-cell: 8px;
    top: calc(10px + var(--decor-cell) * 3.5);
    left: calc(100% + 10px);
    --blocks-x: 3;
    --blocks-y: 5;
    width: calc(var(--decor-cell) * var(--blocks-x));
    aspect-ratio: var(--blocks-x) / var(--blocks-y);
    background-color: var(--color-secondary-light);
    -webkit-mask-image: var(--checker-mask-uri);
    mask-image: var(--checker-mask-uri);
    -webkit-mask-size: calc(var(--decor-cell) * 2) calc(var(--decor-cell) * 2);
    mask-size: calc(var(--decor-cell) * 2) calc(var(--decor-cell) * 2);
    -webkit-mask-repeat: repeat;
    mask-repeat: repeat;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    transform: translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .card-info {
    width: 100%;
    background-color: var(--color-secondary-light);
    border-radius: 94.5px 20px 20px 0px;
    padding: calc(20% + 12px) 24px 24px 24px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: -20%;
    z-index: 1;
  }

  .card-info__text {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding-right: 16px;
  }
  .card-info__text .card-title {
    font-size: clamp(1rem, 5vw, 1.3rem);
    font-weight: 900;
    color: var(--color-secondary-darker);
    line-height: 1.1;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-info__text .card-sub {
    font-size: clamp(0.75rem, 3.5vw, 0.85rem);
    font-weight: 700;
    color: var(--color-secondary-darker);
    margin: 0;
  }

  .card-play-btn {
    width: 0;
    height: 0;
    border-top: 15px solid transparent;
    border-bottom: 15px solid transparent;
    border-left: 20px solid var(--base-white);
    transform: translateX(-10px);
  }

  .card-tags {
    display: flex;
    align-items: stretch;
    margin-top: 12px;
    width: 100%;
  }
  .tag-cat {
    --tag-color: var(--color-primary);
    background-color: var(--tag-color);
    color: var(--base-white);
    font-size: 14px;
    font-weight: 900;
    padding: 0 16px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    position: relative;
    white-space: nowrap;
    margin-right: 50px;
  }
