---
import type { Page } from "astro";
import type { Video } from "../../../lib/hygraph";
import SectionHeader from "../../../components/SectionHeader.astro";
import FilterMenu from "../../../components/FilterMenu.astro";
import MotionCard from "./MotionCard.astro";

interface Props {
  page: Page<Video>;
}

const { page } = Astro.props;
---

<div class="works-content">
  <motion-gallery-manager>
    <section class="gallery-view" id="works-gallery">
      <SectionHeader
        title="MOTIONS"
        subtitle="モーションプロジェクト"
        subtitleOrientation="stacked"
        align="responsive"
      />

      <div class="wrapper motions-wrapper">
        <div class="gallery-layout-split">
          <aside class="sidebar-desktop">
            <div class="sidebar-sticky-wrap">
              <div class="sidebar-group">
                <button class="s-btn grid-btn" data-cols="2" aria-label="2 Cột">
                  <svg viewBox="0 0 32 32"><use href="#icon-grid-2"></use></svg>
                </button>
                <button class="s-btn grid-btn" data-cols="3" aria-label="3 Cột">
                  <svg viewBox="0 0 32 32"><use href="#icon-grid-3"></use></svg>
                </button>
                <button
                  class="s-btn grid-btn active"
                  data-cols="4"
                  aria-label="4 Cột"
                >
                  <svg viewBox="0 0 42 42"><use href="#icon-grid-4"></use></svg>
                </button>
              </div>

              <div class="sidebar-group filter-group">
                <button
                  class="s-btn filter-btn vertical-text active"
                  data-value="all">ALL</button
                >
                <button
                  class="s-btn filter-btn vertical-text"
                  data-value="featured">FEATURED</button
                >
              </div>
            </div>
          </aside>
          <div class="gallery-main">
            <FilterMenu
              groupName="motions-filter"
              options={[
                { label: "ALL MOTIONS", value: "all" },
                { label: "MUSIC VIDEOS // MVs", value: "musicvideos//mvs" },
                { label: "DEBUT // TRAILER", value: "debut//trailer" },
              ]}
            />

            <div
              class="motions-grid"
              id="motions-grid-container"
              data-grid-cols="default"
            >
              {
                page.data.map((vid, index) => {
                  const catMatch =
                    vid.category?.name?.toLowerCase().replace(/\s+/g, "") ||
                    "all";
                  const visMatch = vid.isFeatured ? "featured" : "all";

                  return (
                    <MotionCard
                      vid={vid}
                      index={index}
                      catMatch={catMatch}
                      visMatch={visMatch}
                    />
                  );
                })
              }
            </div>
          </div>
        </div>

        <!-- Client-Side Pagination -->
        <nav
          class="kime-pagination"
          role="navigation"
          aria-label="Pagination"
          id="motion-pagination"
        ></nav>
      </div>
    </section>
  </motion-gallery-manager>
</div>

<script>
  class MotionGalleryManager
    extends HTMLElement
    implements EventListenerObject
  {
    private get _cards() {
      return this.querySelectorAll<HTMLElement>(".motion-card");
    }
    private _currentCat = "all";
    private _currentVis = "all";
    private _currentPage = 1;
    private readonly _pageSize = 12;

    private _resizeHandler = () => {
      requestAnimationFrame(() => {
        this.querySelectorAll(".sidebar-group").forEach((group) => {
          const activeBtn = group.querySelector(".s-btn.active") as HTMLElement;
          if (activeBtn) {
            if (activeBtn.offsetHeight === 0) {
              (group as HTMLElement).style.setProperty(
                "--tracker-opacity",
                "0",
              );
            } else {
              const offsetTop =
                activeBtn.offsetTop + activeBtn.offsetHeight / 2;
              (group as HTMLElement).style.setProperty(
                "--tracker-y",
                `${offsetTop}px`,
              );
              (group as HTMLElement).style.setProperty(
                "--tracker-opacity",
                "1",
              );
            }
          }
        });
      });
    };

    private performFLIP(updateDOMCallback: () => void) {
      if (this._cards.length === 0) return;

      const firstRects = new Map<HTMLElement, DOMRect>();
      this._cards.forEach((card) => {
        if (!card.hidden) firstRects.set(card, card.getBoundingClientRect());
      });

      updateDOMCallback();

      const lastRects = new Map<HTMLElement, DOMRect>();
      this._cards.forEach((card) => {
        if (!card.hidden) lastRects.set(card, card.getBoundingClientRect());
      });

      this._cards.forEach((card) => {
        if (card.hidden || !firstRects.has(card)) return;

        const first = firstRects.get(card)!;
        const last = lastRects.get(card)!;

        const dx = first.left - last.left;
        const dy = first.top - last.top;
        const dw = first.width / last.width;
        const dh = first.height / last.height;

        if (dx === 0 && dy === 0 && dw === 1 && dh === 1) return;

        card.style.transition = "none";
        card.style.transformOrigin = "top left";
        card.style.transform = `translate(${dx}px, ${dy}px) scale(${dw}, ${dh})`;
        card.style.zIndex = "10";

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            card.style.transition =
              "transform 0.5s cubic-bezier(0.22, 1, 0.36, 1)";
            card.style.transform = "";

            const cleanup = () => {
              card.style.transition = "";
              card.style.transformOrigin = "";
              card.style.zIndex = "";
              card.removeEventListener("transitionend", cleanup);
            };
            card.addEventListener("transitionend", cleanup);
          });
        });
      });
    }

    private updateCardThemes() {
      requestAnimationFrame(() => {
        if (this._cards.length === 0) return;
        const grid = this.querySelector<HTMLElement>("#motions-grid-container");
        let cols = parseInt(grid?.dataset.gridCols || "4", 10);
        if (isNaN(cols)) cols = 4;

        let visibleIndex = 0;
        this._cards.forEach((card) => {
          if (!card.hidden) {
            const isPink = Math.floor(visibleIndex / cols) % 2 === 0;
            const newTheme = isPink ? "pink" : "blue";
            if (card.dataset.theme !== newTheme) {
              card.dataset.theme = newTheme;
            }
            visibleIndex++;
          }
        });
      });
    }

    // =============================================
    //  CLIENT-SIDE PAGINATION ENGINE
    // =============================================

    private _getFilteredCards(): HTMLElement[] {
      return Array.from(this._cards).filter((card) => {
        const matchCat =
          this._currentCat === "all" ||
          card.dataset.category === this._currentCat;
        const matchVis =
          this._currentVis === "all" ||
          card.dataset.visibility === this._currentVis;
        return matchCat && matchVis;
      });
    }

    private _applyVisibility() {
      const allCards = Array.from(this._cards);
      const filtered = this._getFilteredCards();
      const totalPages = Math.max(
        1,
        Math.ceil(filtered.length / this._pageSize),
      );
      if (this._currentPage > totalPages) this._currentPage = totalPages;

      const start = (this._currentPage - 1) * this._pageSize;
      const pageSet = new Set(filtered.slice(start, start + this._pageSize));

      allCards.forEach((card) => {
        card.hidden = !pageSet.has(card);
      });

      this._renderPagination(totalPages);
      this.updateCardThemes();
    }

    private _renderPagination(totalPages: number) {
      const container = this.querySelector<HTMLElement>("#motion-pagination");
      if (!container) return;

      const MAX_VISIBLE = 5;
      let ws = Math.max(
        1,
        this._currentPage - Math.floor(MAX_VISIBLE / 2),
      );
      let we = ws + MAX_VISIBLE - 1;
      if (we > totalPages) {
        we = totalPages;
        ws = Math.max(1, we - MAX_VISIBLE + 1);
      }

      const prevPage =
        this._currentPage > 1 ? this._currentPage - 1 : totalPages;
      const nextPage =
        this._currentPage < totalPages ? this._currentPage + 1 : 1;

      let html = `<button class="page-nav-btn prev-btn" data-page="${prevPage}" aria-label="Previous page">PREVIOUS</button>`;
      html += `<ul class="page-numbers">`;
      for (let p = ws; p <= we; p++) {
        const active = p === this._currentPage;
        html += `<li><button class="page-link${active ? " is-active" : ""}" data-page="${p}" ${active ? 'aria-current="page"' : ""} aria-label="Page ${p}">${p}</button></li>`;
      }
      html += `</ul>`;
      html += `<button class="page-nav-btn next-btn" data-page="${nextPage}" aria-label="Next page">NEXT</button>`;

      container.innerHTML = html;
    }

    /** Handle page button clicks with FLIP + smooth scroll */
    private _handlePaginationClick(btn: HTMLElement) {
      const page = parseInt(btn.dataset.page || "1", 10);
      if (page === this._currentPage || isNaN(page)) return;
      this._currentPage = page;

      const gallery = this.querySelector("#works-gallery");
      if (gallery)
        gallery.scrollIntoView({ behavior: "smooth", block: "start" });

      this.performFLIP(() => this._applyVisibility());
    }

    // =============================================
    //  LIFECYCLE
    // =============================================

    connectedCallback() {
      const grid = this.querySelector<HTMLElement>("#motions-grid-container");
      const sidebarBtns = this.querySelectorAll<HTMLButtonElement>(".s-btn");

      // Restore grid column preference
      const savedCols = localStorage.getItem("kime-motions-cols");
      if (savedCols && grid) {
        grid.dataset.gridCols = savedCols;
        sidebarBtns.forEach((b) => {
          if (b.classList.contains("grid-btn")) {
            if (b.dataset.cols === savedCols) b.classList.add("active");
            else b.classList.remove("active");
          }
        });
      }

      this._applyVisibility();

      window.addEventListener("resize", this._resizeHandler);
      this._resizeHandler();

      this.addEventListener("filter-changed", this);
      this.addEventListener("click", this);

      // Keyboard shortcuts: phím 2-4 chuyển cột grid tương ứng
      window.addEventListener("keydown", this._handleKeydown);

      const pendingSidebar = localStorage.getItem("kime-sidebar-pending");
      if (pendingSidebar) {
        localStorage.removeItem("kime-sidebar-pending");

        const targetBtn = this.querySelector<HTMLButtonElement>(
          `.sidebar-desktop .filter-btn[data-value="${CSS.escape(pendingSidebar)}"]`,
        );
        if (targetBtn) {
          this.querySelectorAll(".sidebar-desktop .filter-btn").forEach((b) =>
            b.classList.remove("active"),
          );
          targetBtn.classList.add("active");
          this._updateSidebarTracker(targetBtn);
        }

        requestAnimationFrame(() => {
          this.dispatchEvent(
            new CustomEvent("filter-changed", {
              detail: {
                group: "sidebar",
                value: pendingSidebar,
                isRestore: true,
              },
              bubbles: true,
            }),
          );
        });
      }
    }

    disconnectedCallback() {
      window.removeEventListener("resize", this._resizeHandler);
      window.removeEventListener("keydown", this._handleKeydown);
      this.removeEventListener("filter-changed", this);
      this.removeEventListener("click", this);
    }

    handleEvent(e: Event) {
      if (e.type === "filter-changed") {
        this._handleFilterChange(e as CustomEvent);
      } else if (e.type === "click") {
        const target = e.target as HTMLElement;
        const sidebarBtn = target.closest<HTMLButtonElement>(".s-btn");
        if (sidebarBtn) {
          this._handleSidebarClick(sidebarBtn);
          return;
        }
        // Pagination button delegation
        const pageBtn = target.closest<HTMLElement>("[data-page]");
        if (pageBtn) this._handlePaginationClick(pageBtn);
      }
    }

    // Keyboard shortcut handler: phím 2/3/4 -> chuyển cột grid
    private _handleKeydown = (e: KeyboardEvent) => {
      const active = document.activeElement;
      if (active && (active.tagName === "INPUT" || active.tagName === "TEXTAREA" || (active as HTMLElement).isContentEditable)) return;

      const colMap: Record<string, string> = { "2": "2", "3": "3", "4": "4" };
      const cols = colMap[e.key];
      if (!cols) return;

      const targetBtn = this.querySelector<HTMLButtonElement>(`.grid-btn[data-cols="${cols}"]`);
      if (targetBtn && !targetBtn.classList.contains("active")) {
        this._handleSidebarClick(targetBtn);
      }
    };

    // =============================================
    //  SIDEBAR
    // =============================================

    private _updateSidebarTracker(btn: HTMLElement) {
      const group = btn.closest(".sidebar-group") as HTMLElement;
      if (group) {
        if (btn.offsetHeight === 0) {
          group.style.setProperty("--tracker-opacity", "0");
        } else {
          const offsetTop = btn.offsetTop + btn.offsetHeight / 2;
          group.style.setProperty("--tracker-y", `${offsetTop}px`);
          group.style.setProperty("--tracker-opacity", "1");
        }
      }
    }

    private _handleSidebarClick(btn: HTMLButtonElement) {
      this._updateSidebarTracker(btn);
      const grid = this.querySelector<HTMLElement>("#motions-grid-container");

      if (btn.classList.contains("grid-btn")) {
        this.querySelectorAll(".grid-btn").forEach((b) =>
          b.classList.remove("active"),
        );
        btn.classList.add("active");

        if (
          grid &&
          btn.dataset.cols &&
          grid.dataset.gridCols !== btn.dataset.cols
        ) {
          this.performFLIP(() => {
            grid.dataset.gridCols = btn.dataset.cols!;
            localStorage.setItem("kime-motions-cols", btn.dataset.cols!);
            this.updateCardThemes();
          });
        }
      }

      if (btn.classList.contains("filter-btn")) {
        this.querySelectorAll(
          ".filter-btn:not(filter-menu-ctrl .filter-btn)",
        ).forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        const filterValue = btn.dataset.value;
        if (filterValue) {
          this.dispatchEvent(
            new CustomEvent("filter-changed", {
              detail: { group: "sidebar", value: filterValue },
              bubbles: true,
            }),
          );
        }
      }
    }

    // =============================================
    //  FILTER
    // =============================================

    private _handleFilterChange(e: CustomEvent) {
      if (this._cards.length === 0) return;

      const filterGroup = e.detail.group;
      const filterValue = e.detail.value.toLowerCase();

      if (filterGroup === "sidebar") {
        this._currentVis = filterValue;
      } else {
        this._currentCat = filterValue;
      }

      // Reset to page 1 on any filter change
      this._currentPage = 1;

      this.performFLIP(() => this._applyVisibility());
    }
  }

  if (!customElements.get("motion-gallery-manager")) {
    customElements.define("motion-gallery-manager", MotionGalleryManager);
  }
</script>

<style>
  .works-content {
    padding-top: var(--spacing-8);
  }

  motion-gallery-manager {
    display: block;
    width: 100%;
    min-height: 50vh;
  }

  :global(.motion-card[hidden]) {
    display: none;
  }

  .gallery-layout-split {
    display: flex;
    flex-direction: column;
    margin-top: var(--spacing-8);
  }
  .sidebar-desktop {
    display: none;
  }

  @media (min-width: 1024px) {
    .gallery-layout-split {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: clamp(16px, 4vw, 80px);
    }
    .gallery-main {
      flex: 1;
      width: 100%;
      min-width: 0;
    }
    .sidebar-desktop {
      display: block;
      margin-top: calc(48px + var(--spacing-8));
      position: sticky;
      top: calc(var(--header-height-pc) + var(--spacing-8));
      width: clamp(48px, 4vw, 72px);
      flex-shrink: 0;
    }
    .sidebar-sticky-wrap {
      display: flex;
      flex-direction: column;
      gap: clamp(40px, 4vw, 72px);
      align-items: center;
    }
    .sidebar-group {
      display: flex;
      flex-direction: column;
      gap: clamp(24px, 2vw, 32px);
      align-items: center;
      position: relative;
    }
    .s-btn {
      position: relative;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      padding: 0;
      transition: opacity 0.2s ease;
    }
    .s-btn:active {
      opacity: 0.6;
    }

    .sidebar-group::after {
      content: "";
      position: absolute;
      right: clamp(-24px, -2vw, -32px);
      top: 0;
      transform: translateY(calc(var(--tracker-y, 16px) - 50%));
      width: 0;
      height: 0;
      border-top: 8px solid transparent;
      border-bottom: 8px solid transparent;
      border-right: clamp(10px, 1vw, 14px) solid var(--color-primary);
      will-change: transform;
      transition:
        transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
        opacity 0.2s ease;
      opacity: var(--tracker-opacity, 1);
    }

    .grid-btn svg {
      width: clamp(32px, 3vw, 44px);
      height: clamp(32px, 3vw, 44px);
      fill: rgba(250, 114, 157, 0.3);
      transition: fill 0.2s ease;
    }
    .grid-btn:hover svg {
      fill: rgba(250, 114, 157, 0.7);
    }
    .grid-btn.active svg {
      fill: var(--color-primary);
    }

    .vertical-text {
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-size: clamp(16px, 1.5vw, 22px);
      font-weight: 899;
      letter-spacing: 3px;
      color: #b0b0b0;
      text-transform: uppercase;
    }
    .vertical-text:hover {
      color: var(--color-primary-light);
    }
    .vertical-text.active {
      color: var(--base-black-800);
    }
  }

  .motions-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8);
    padding-top: var(--spacing-4);
    padding-bottom: var(--spacing-12);
  }

  /* ==============================================
     GRID RESPONSIVE ARCHITECTURE
     ============================================== */
  @media (max-width: 1199px) {
    .grid-btn[data-cols="3"],
    .grid-btn[data-cols="4"] {
      display: none;
    }
  }

  @media (max-width: 1760px) {
    .grid-btn[data-cols="4"] {
      display: none !important;
    }

    .motions-grid[data-grid-cols="4"],
    .motions-grid[data-grid-cols="default"] {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }

  @media (max-width: 1380px) {
    .grid-btn[data-cols="3"] {
      display: none !important;
    }

    .motions-grid[data-grid-cols="3"],
    .motions-grid[data-grid-cols="4"],
    .motions-grid[data-grid-cols="default"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (max-width: 767px) {
    .motions-grid,
    .motions-grid[data-grid-cols] {
      grid-template-columns: 1fr !important;
    }
  }

  @media (min-width: 768px) {
    .motions-grid[data-grid-cols="default"],
    .motions-grid[data-grid-cols="2"] {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-10);
    }
    .motions-grid[data-grid-cols="default"] :global(.card-footer),
    .motions-grid[data-grid-cols="2"] :global(.card-footer) {
      flex-direction: row;
      height: 34px;
      align-items: center;
      gap: var(--spacing-3);
    }
  }

  @media (min-width: 1024px) {
    .motions-grid[data-grid-cols="default"] {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-12);
    }
  }

  @media (min-width: 1200px) {
    .motions-grid[data-grid-cols="3"] {
      grid-template-columns: repeat(3, 1fr);
    }
    .motions-grid[data-grid-cols="3"] :global(.card-footer) {
      flex-direction: row;
      height: 34px;
      align-items: center;
      gap: var(--spacing-3);
    }

    .motions-grid[data-grid-cols="4"] {
      grid-template-columns: repeat(4, 1fr);
    }
    .motions-grid[data-grid-cols="4"] :global(.card-footer) {
      flex-direction: column;
      height: auto;
      align-items: flex-start;
      gap: var(--spacing-2);
    }
  }

  @media (min-width: 1280px) {
    .motions-grid[data-grid-cols="default"] {
      grid-template-columns: repeat(4, 1fr);
    }
    .motions-grid[data-grid-cols="default"] :global(.card-footer) {
      flex-direction: column;
      height: auto;
      align-items: flex-start;
      gap: var(--spacing-2);
    }
  }

  @media (min-width: 1024px) {
    .motions-wrapper {
      max-width: 90%;
    }

    :global(#motion-pagination) {
      margin-left: clamp(64px, 8vw, 152px);
      width: calc(100% - clamp(64px, 8vw, 152px));
    }
  }

  @media (min-width: 1536px) {
    .motions-grid[data-grid-cols="default"],
    .motions-grid[data-grid-cols="4"] {
      grid-template-columns: repeat(4, 1fr);
    }
    .motions-grid[data-grid-cols="default"] :global(.card-footer),
    .motions-grid[data-grid-cols="4"] :global(.card-footer) {
      flex-direction: row;
      height: 34px;
      align-items: center;
      gap: var(--spacing-3);
    }
  }

  /* ==============================================
     CLIENT-SIDE PAGINATION (DYNAMIC)
     Mirrors Pagination.astro visual design
     ============================================== */
  :global(#motion-pagination) {
    --cell: 30px;
    --checker-w: round(nearest, calc(var(--cell) * 1.5), 1px);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    margin-top: clamp(var(--spacing-8), 6vw, var(--spacing-12));
  }
  :global(#motion-pagination:empty) {
    display: none;
  }
  :global(#motion-pagination .page-nav-btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: clamp(130px, 15vw, 170px);
    min-width: 130px;
    height: round(nearest, calc(var(--cell) * 1.5), 1px);
    color: var(--text-inverse);
    font-weight: 899;
    font-size: clamp(var(--text-base), 2vw, var(--text-lg));
    font-family: inherit;
    line-height: 1;
    text-decoration: none;
    background-color: var(--color-primary);
    border: none;
    cursor: pointer;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
    /* PNG mask: solid layer (text area) + checker layer (pattern area) */
    -webkit-mask-image:
      linear-gradient(black, black),
      var(--checker-mask-uri);
    mask-image:
      linear-gradient(black, black),
      var(--checker-mask-uri);
    -webkit-mask-size:
      calc(100% - var(--checker-w) + 1px) 100%,
      round(nearest, var(--cell), 1px) round(nearest, var(--cell), 1px);
    mask-size:
      calc(100% - var(--checker-w) + 1px) 100%,
      round(nearest, var(--cell), 1px) round(nearest, var(--cell), 1px);
    -webkit-mask-repeat: no-repeat, repeat;
    mask-repeat: no-repeat, repeat;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }
  :global(#motion-pagination .page-nav-btn:hover) {
    transform: translateY(-2px);
  }
  :global(#motion-pagination .prev-btn) {
    padding: 0
      calc(
        clamp(var(--spacing-3), 2vw, var(--spacing-36)) + var(--checker-w)
      )
      0 clamp(var(--spacing-3), 2vw, var(--spacing-6));
    -webkit-mask-position: left top, right calc(var(--cell) / 2);
    mask-position: left top, right calc(var(--cell) / 2);
    justify-self: start;
  }
  :global(#motion-pagination .next-btn) {
    padding: 0 clamp(var(--spacing-3), 2vw, var(--spacing-6)) 0
      calc(
        clamp(var(--spacing-3), 2vw, var(--spacing-36)) + var(--checker-w)
